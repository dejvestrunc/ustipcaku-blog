---
import BaseLayout from './BaseLayout.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import ProductCTA from '../components/ProductCTA.astro';
import ArticleCard from '../components/ArticleCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  relatedArticles: CollectionEntry<'articles'>[];
}

const { article, relatedArticles } = Astro.props;
const { title, description, date, category, categoryLabel, tags, productLinks, image } = article.data;

const formattedDate = date.toLocaleDateString('cs-CZ', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image}>
  <article class="article container">
    <header class="article-header">
      <div class="article-meta">
        <CategoryBadge category={category} label={categoryLabel} />
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
      <h1>{title}</h1>
      <p class="article-description">{description}</p>
    </header>

    {image && (
      <img src={image} alt={title} class="article-hero" />
    )}

    <div class="article-content">
      <slot />
    </div>

    {productLinks && productLinks.length > 0 && (
      <ProductCTA links={productLinks} />
    )}

    {tags && tags.length > 0 && (
      <div class="article-tags">
        {tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </article>

  {relatedArticles.length > 0 && (
    <section class="related container">
      <h2>Další články</h2>
      <div class="related-grid">
        {relatedArticles.map(related => (
          <ArticleCard
            title={related.data.title}
            description={related.data.description}
            date={related.data.date}
            category={related.data.category}
            categoryLabel={related.data.categoryLabel}
            slug={related.id}
            image={related.data.image}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .article {
    max-width: 800px;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .article-header h1 {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }

  .article-description {
    font-size: 1.15rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .article-hero {
    width: 100%;
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .article-content {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .article-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }

  .article-content :global(h3) {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .article-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background: var(--color-bg-light);
    border-radius: 0 8px 8px 0;
    font-style: italic;
  }

  .article-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: var(--color-bg-light);
    border-radius: 20px;
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .related {
    max-width: 1000px;
    padding-bottom: 2rem;
  }

  .related h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 600px) {
    .article-header h1 {
      font-size: 1.75rem;
    }
  }
</style>
